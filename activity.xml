<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Spacer to push content down -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.5" />

    <!-- Text Input -->
    <EditText
        android:id="@+id/inputText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:autofillHints="Add Text"
        android:hint="Enter text to speak"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:minLines="3"
        android:maxLines="5"
        android:scrollbars="vertical"
        tools:ignore="HardcodedText" />

    <!-- ScrollView for TTS options to prevent overflow -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Native TTS Section -->
            <LinearLayout
                android:id="@+id/nativeTtsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/nativeTtsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Native TTS"
                    tools:ignore="HardcodedText" />

                <EditText
                    android:id="@+id/nativeSpeedInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Speed"
                    android:inputType="numberDecimal"
                    android:text="1.0"
                    android:gravity="center"
                    android:layout_marginStart="8dp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <TextView
                android:id="@+id/nativeLatencyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="native latency: -"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="2dp"
                android:padding="6dp" />

            <TextView
                android:id="@+id/nativeEnergyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="energy metrics: -"
                android:textSize="10sp"
                android:layout_marginBottom="12dp"
                android:padding="6dp" />

            <!-- Kokoro TTS Section -->
            <LinearLayout
                android:id="@+id/kokoroTtsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/kokoroTtsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Kokoro TTS"
                    tools:ignore="HardcodedText" />

                <EditText
                    android:id="@+id/kokoroSpeedInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Speed"
                    android:inputType="numberDecimal"
                    android:text="1.0"
                    android:gravity="center"
                    android:layout_marginStart="8dp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <TextView
                android:id="@+id/kokoroLatencyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="kokoro latency: -"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="2dp"
                android:padding="6dp" />

            <TextView
                android:id="@+id/kokoroEnergyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="energy metrics: -"
                android:textSize="10sp"
                android:layout_marginBottom="12dp"
                android:padding="6dp" />

            <!-- Kitten Nano TTS Section -->
            <LinearLayout
                android:id="@+id/kittenTtsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/kittenTtsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Kitten Nano TTS"
                    tools:ignore="HardcodedText" />

                <EditText
                    android:id="@+id/kittenSpeedInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Speed"
                    android:inputType="numberDecimal"
                    android:text="1.0"
                    android:gravity="center"
                    android:layout_marginStart="8dp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <TextView
                android:id="@+id/kittenLatencyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="kitten latency: -"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="2dp"
                android:padding="6dp" />

            <TextView
                android:id="@+id/kittenEnergyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="energy metrics: -"
                android:textSize="10sp"
                android:layout_marginBottom="12dp"
                android:padding="6dp" />

            <!-- Piper TTS Section -->
            <LinearLayout
                android:id="@+id/piperTtsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/piperTtsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="Piper Start"
                    tools:ignore="HardcodedText" />

                <EditText
                    android:id="@+id/piperSpeedInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Speed"
                    android:inputType="numberDecimal"
                    android:text="1.0"
                    android:gravity="center"
                    android:layout_marginStart="8dp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <TextView
                android:id="@+id/piperLatencyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="piper latency: -"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="2dp"
                android:padding="6dp" />

            <TextView
                android:id="@+id/piperEnergyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="energy metrics: -"
                android:textSize="10sp"
                android:layout_marginBottom="12dp"
                android:padding="6dp" />

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Spacer -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.5" />

</LinearLayout>